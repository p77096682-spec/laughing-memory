<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Mưa Trái Cây</title>
    <style>
        body {
            margin: 0;
            background: #1a1a1a;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
            overflow: hidden;
        }
        #gameContainer {
            position: relative;
        }
        canvas {
            background: #87CEEB; /* Màu bầu trời */
            border: 4px solid #fff;
            border-radius: 12px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
            cursor: none;
        }
        #scoreBoard {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <div id="scoreBoard">Điểm của bạn: <span id="score">0</span></div>
    <div id="gameContainer">
        <canvas id="gameCanvas" width="450" height="600"></canvas>
    </div>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreDisplay = document.getElementById('score');

    let score = 0;
    let gameOver = false;

    // Cấu hình Giỏ hứng (Người chơi)
    const basket = {
        x: 200,
        y: 540,
        width: 80,
        height: 30,
        color: '#8B4513' // Màu nâu gỗ
    };

    // Danh sách các loại trái cây rơi xuống
    const fruitTypes = [
        { icon: '🍎', points: 10, speedMin: 2, speedMax: 4 },
        { icon: '🍌', points: 15, speedMin: 3, speedMax: 5 },
        { icon: '🍉', points: 20, speedMin: 2, speedMax: 3 },
        { icon: '🍇', points: 25, speedMin: 4, speedMax: 6 },
        { icon: '💣', points: -50, speedMin: 4, speedMax: 7 } // Bom né ra nhé!
    ];

    const fruits = [];

    // Tạo trái cây ngẫu nhiên
    function spawnFruit() {
        if (gameOver) return;
        const type = fruitTypes[Math.floor(Math.random() * fruitTypes.length)];
        fruits.push({
            x: Math.random() * (canvas.width - 30) + 15,
            y: -30,
            size: 30,
            icon: type.icon,
            points: type.points,
            speed: Math.random() * (type.speedMax - type.speedMin) + type.speedMin
        });
        // Càng nhiều điểm trái cây rơi càng nhanh
        setTimeout(spawnFruit, Math.max(300, 1000 - score * 2));
    }

    // Điều khiển giỏ bằng chuột hoặc cảm ứng
    window.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        basket.x = e.clientX - rect.left - basket.width / 2;
        // Giới hạn giỏ trong canvas
        if (basket.x < 0) basket.x = 0;
        if (basket.x > canvas.width - basket.width) basket.x = canvas.width - basket.width;
    });

    window.addEventListener('touchmove', (e) => {
        const rect = canvas.getBoundingClientRect();
        basket.x = e.touches[0].clientX - rect.left - basket.width / 2;
        if (basket.x < 0) basket.x = 0;
        if (basket.x > canvas.width - basket.width) basket.x = canvas.width - basket.width;
    });

    // Vòng lặp Game (Game Loop)
    function update() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Vẽ cái giỏ
        ctx.fillStyle = basket.color;
        ctx.beginPath();
        ctx.roundRect(basket.x, basket.y, basket.width, basket.height, 10);
        ctx.fill();
        // Vẽ vân giỏ cho đẹp
        ctx.fillStyle = '#a0522d';
        ctx.fillRect(basket.x + 5, basket.y + 10, basket.width - 10, 5);

        // Xử lý trái cây
        for (let i = fruits.length - 1; i >= 0; i--) {
            let f = fruits[i];
            f.y += f.speed;

            // Vẽ Trái cây (Emoji)
            ctx.font = f.size + "px Arial";
            ctx.textAlign = "center";
            ctx.fillText(f.icon, f.x, f.y);

            // Kiểm tra va chạm (Ăn trái cây)
            if (f.y + 10 >= basket.y && f.y - 10 <= basket.y + basket.height &&
                f.x >= basket.x && f.x <= basket.x + basket.width) {
                
                score += f.points;
                if (score < 0) score = 0; // Không để điểm âm
                scoreDisplay.innerText = score;
                
                // Xóa trái cây đã ăn
                fruits.splice(i, 1);
                continue;
            }

            // Nếu rơi ra ngoài màn hình thì xóa
            if (f.y > canvas.height + 20) {
                fruits.splice(i, 1);
            }
        }

        requestAnimationFrame(update);
    }

    // Khởi chạy game
    spawnFruit();
    update();
</script>

</body>
</html>
